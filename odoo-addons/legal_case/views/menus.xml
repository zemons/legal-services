<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Top-level menu (standalone, not under CRM) -->
    <menuitem id="menu_legal_root"
              name="Legal"
              web_icon="legal_case,static/description/icon.png"
              sequence="50"/>

    <!-- Cases (CRM Leads with legal fields) -->
    <record id="action_legal_cases" model="ir.actions.act_window">
        <field name="name">Cases</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

    <menuitem id="menu_legal_cases"
              name="Cases"
              parent="menu_legal_root"
              action="action_legal_cases"
              sequence="5"/>

    <!-- Courts -->
    <record id="action_legal_court" model="ir.actions.act_window">
        <field name="name">Courts</field>
        <field name="res_model">legal.court</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_legal_court"
              name="Courts"
              parent="menu_legal_root"
              action="action_legal_court"
              sequence="10"/>

    <!-- Court Dates -->
    <record id="action_legal_court_date" model="ir.actions.act_window">
        <field name="name">Court Dates</field>
        <field name="res_model">legal.court.date</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_legal_court_date"
              name="Court Dates"
              parent="menu_legal_root"
              action="action_legal_court_date"
              sequence="20"/>

</odoo>
