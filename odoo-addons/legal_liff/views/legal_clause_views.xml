<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ CLAUSE CATEGORY ═══════════════════════════════════ -->

    <record id="view_legal_clause_category_tree" model="ir.ui.view">
        <field name="name">legal.clause.category.tree</field>
        <field name="model">legal.clause.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="parent_id"/>
                <field name="clause_count"/>
            </list>
        </field>
    </record>

    <record id="view_legal_clause_category_form" model="ir.ui.view">
        <field name="name">legal.clause.category.form</field>
        <field name="model">legal.clause.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="parent_id"/>
                            <field name="clause_count"/>
                        </group>
                    </group>
                    <field name="description" placeholder="คำอธิบายหมวดหมู่..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_legal_clause_category" model="ir.actions.act_window">
        <field name="name">Clause Categories</field>
        <field name="res_model">legal.clause.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ═══ CLAUSE ════════════════════════════════════════════ -->

    <record id="view_legal_clause_tree" model="ir.ui.view">
        <field name="name">legal.clause.tree</field>
        <field name="model">legal.clause</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="category_id"/>
                <field name="risk_level" widget="badge"
                       decoration-success="risk_level == 'conservative'"
                       decoration-warning="risk_level == 'standard'"
                       decoration-danger="risk_level == 'aggressive'"/>
                <field name="document_types"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'review'"
                       decoration-success="state == 'approved'"
                       decoration-muted="state == 'archived'"/>
                <field name="version"/>
                <field name="usage_count"/>
                <field name="legal_reference"/>
            </list>
        </field>
    </record>

    <record id="view_legal_clause_form" model="ir.ui.view">
        <field name="name">legal.clause.form</field>
        <field name="model">legal.clause</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit_review" type="object" string="Submit for Review"
                            invisible="state != 'draft'" class="oe_highlight"/>
                    <button name="action_approve" type="object" string="Approve"
                            invisible="state != 'review'" class="oe_highlight"/>
                    <button name="action_new_version" type="object" string="New Version"
                            invisible="state != 'approved'"/>
                    <button name="action_archive" type="object" string="Archive"
                            invisible="state in ('archived', 'draft')"/>
                    <button name="action_back_to_draft" type="object" string="Back to Draft"
                            invisible="state not in ('review', 'archived')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,review,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Clause Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="category_id"/>
                            <field name="risk_level"/>
                            <field name="document_types"/>
                        </group>
                        <group>
                            <field name="jurisdiction"/>
                            <field name="legal_reference"/>
                            <field name="version"/>
                            <field name="usage_count"/>
                            <field name="tags"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Content" name="content">
                            <field name="content" widget="ace" options="{'mode': 'markdown'}"/>
                        </page>
                        <page string="Preview" name="preview">
                            <field name="content_html"/>
                        </page>
                        <page string="Templates" name="templates">
                            <field name="template_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Approval" name="approval">
                            <group>
                                <field name="approved_by"/>
                                <field name="approved_date"/>
                            </group>
                            <field name="notes" placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_legal_clause_search" model="ir.ui.view">
        <field name="name">legal.clause.search</field>
        <field name="model">legal.clause</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="tags"/>
                <field name="legal_reference"/>
                <filter name="approved" string="Approved" domain="[('state','=','approved')]"/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <separator/>
                <filter name="conservative" string="Conservative" domain="[('risk_level','=','conservative')]"/>
                <filter name="standard" string="Standard" domain="[('risk_level','=','standard')]"/>
                <filter name="aggressive" string="Aggressive" domain="[('risk_level','=','aggressive')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_category" string="Category" context="{'group_by': 'category_id'}"/>
                    <filter name="group_risk" string="Risk Level" context="{'group_by': 'risk_level'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_doc_type" string="Document Type" context="{'group_by': 'document_types'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_legal_clause" model="ir.actions.act_window">
        <field name="name">Clause Library</field>
        <field name="res_model">legal.clause</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_approved': 1}</field>
    </record>

    <!-- ═══ MENUS ═════════════════════════════════════════════ -->

    <menuitem id="menu_legal_clause_root"
              name="Clause Library"
              parent="legal_case.menu_legal_root"
              sequence="30"/>

    <menuitem id="menu_legal_clause_list"
              name="Clauses"
              parent="menu_legal_clause_root"
              action="action_legal_clause"
              sequence="10"/>

    <menuitem id="menu_legal_clause_category"
              name="Categories"
              parent="menu_legal_clause_root"
              action="action_legal_clause_category"
              sequence="20"/>

</odoo>
